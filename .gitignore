node_modules/
backend/.env
backend/data/
backend/uploads/submissions/*
!backend/uploads/submissions/.gitkeep
*.log
.DS_Store

# backend/seed-assets/ is intentionally NOT ignored — these are small
# placeholder painting images shipped with the repo so `npm run seed`
# can create realistic-looking sample submissions out of the box.
# They are copied into uploads/submissions/ at seed time, not edited
# directly, so they're safe to keep in git unlike real user uploads.
