# Copy this file to .env and adjust values before running the server

PORT=4000
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
DB_PATH=./data/ifa.db
UPLOAD_DIR=./uploads/submissions
MAX_UPLOAD_MB=8

# Email notifications (optional). Leave SMTP_HOST blank to run without
# real email — notifications will just be printed to the server console
# instead, so the feature is still fully demoable with zero setup.
#
# Example for Gmail: create an "App Password" (not your normal password)
# at https://myaccount.google.com/apppasswords, then:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASS=your16charapppassword
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@ifa.edu
SMTP_FROM_NAME=Institute of Fine Arts
